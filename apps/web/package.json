{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "deadcode": "bash scripts/check-deadcode.sh",
    "deadcode:full": "DOTENV_CONFIG_PATH=.env.local node -r dotenv/config ../../node_modules/.bin/knip",
    "deps:unused": "depcheck",
    "cleanup:scan": "npm run lint && npm run deadcode && npm run deps:unused",
    "db:generate": "DOTENV_CONFIG_PATH=.env.local node -r dotenv/config ../../node_modules/.bin/drizzle-kit generate",
    "db:migrate": "DOTENV_CONFIG_PATH=.env.local node -r dotenv/config ../../node_modules/.bin/drizzle-kit migrate",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "db:seed": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/seed-admin.ts"
  },
