# Local Development Environment
# Copy this file to .env.local and fill in the values

# ============================================================
# BYPASS MODE — run without a database
# Set both variables below to skip the DB entirely.
# Active when DEV_ADMIN_EMAIL is set AND DATABASE_URL is not.
# Login with these credentials at http://localhost:3000/login
# ============================================================
# DEV_ADMIN_EMAIL=admin@dev.local
# DEV_ADMIN_PASSWORD=admin123

# ============================================================
# Database — required when NOT using bypass mode above
# Run: npm run db:local:start (requires Docker)
# ============================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ============================================================
# NextAuth
# ============================================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-local-nextauth-secret-min-32-chars  # openssl rand -base64 32

# ============================================================
# Theme — optional color overrides (all values are CSS colors)
# Uncomment and change any value to retheme the app.
# Default values (current palette) are shown as comments.
# ============================================================
# THEME_PRIMARY=#6366f1          # Main accent: buttons, active nav, links
# THEME_PRIMARY_DARK=#4338ca     # Hover states on primary elements
# THEME_PRIMARY_SOFT=#818cf8     # Focus rings, secondary accents
# THEME_PRIMARY_LIGHT=#c7d2fe    # Subtle tinted backgrounds
# THEME_PRIMARY_EXTRA_LIGHT=#eef2ff  # Near-white primary-hued surfaces
# THEME_SIDEBAR_BG=#2d322b       # Sidebar background
# THEME_PAGE_BG=#f7f9f6          # Main page background

# ============================================================
# DEV Database Sync (optional)
# Used by: npm run db:local:sync
# Use Session Pooler URL from Supabase > Connect (port 6543)
# ============================================================
# SUPABASE_DEV_DB_URL=postgresql://postgres.XXX:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# ============================================================
# External API Integration (optional)
# ============================================================
# EXTERNAL_API_BASE_URL=https://api.example.com/graphql
# EXTERNAL_OAUTH_REFRESH_URL=https://api.example.com/auth/refresh
# EXTERNAL_TOKENS_ENC_KEY=<32-byte-base64-key>
